  "category_substitution_rules": {
    "_description": "Rules for when one food can reasonably substitute for another in a recipe. Used by the recipe matching system (WS05) to suggest alternatives when an exact ingredient is missing. Sub-categories enable smarter matching — substituting within a sub-category is more reliable than across them.",
    "protein": {
      "substitutable_within_subcategory": true,
      "sub_categories": {
        "poultry": ["chicken", "chicken breast", "chicken thigh", "turkey", "duck", "cornish hen"],
        "red_meat": ["beef", "ground beef", "steak", "pork", "pork chop", "lamb", "veal", "bison"],
        "seafood": ["salmon", "tuna", "shrimp", "cod", "tilapia", "halibut", "mahi mahi", "crab", "lobster", "scallops"],
        "plant_protein": ["tofu", "tempeh", "seitan", "beans", "black beans", "kidney beans", "chickpeas", "lentils", "edamame"]
      },
      "notes": "Substitutions within sub-categories usually work (chicken for turkey). Across sub-categories is risky (tofu for steak changes the dish significantly)."
    },
    "dairy": {
      "substitutable_within_subcategory": true,
      "sub_categories": {
        "cheese_hard": ["cheddar", "swiss", "provolone", "gouda", "gruyere", "parmesan", "pecorino"],
        "cheese_soft": ["mozzarella", "brie", "camembert", "cream cheese", "ricotta", "cottage cheese", "goat cheese"],
        "milk_liquid": ["milk", "half and half", "buttermilk"],
        "cream": ["heavy cream", "whipping cream", "sour cream", "creme fraiche"],
        "cultured": ["yogurt", "greek yogurt", "kefir"]
      },
      "notes": "Hard cheeses can often swap. Soft cheeses are trickier. Milk and cream have different fat content affecting recipes."
    },
    "grain": {
      "substitutable_within_subcategory": true,
      "sub_categories": {
        "pasta": ["spaghetti", "penne", "fettuccine", "linguine", "macaroni", "rigatoni", "farfalle", "rotini", "orzo", "angel hair"],
        "rice": ["white rice", "rice", "jasmine rice", "basmati rice", "brown rice", "arborio rice"],
        "bread": ["bread", "sourdough", "wheat bread", "white bread", "ciabatta", "baguette", "pita", "naan"],
        "flour": ["flour", "all-purpose flour", "bread flour", "whole wheat flour"]
      },
      "notes": "Pasta shapes are highly interchangeable. Rice varieties mostly swap well. Bread types depend on the recipe."
    },
    "vegetable": {
      "substitutable_within_subcategory": false,
      "notes": "Vegetables are generally NOT substitutable — carrots and spinach serve very different purposes in a recipe. The category match is listed as a suggestion only, not a reliable swap."
    },
    "fruit": {
      "substitutable_within_subcategory": false,
      "notes": "Fruits are rarely directly substitutable — apple and mango have very different flavors and textures."
    },
    "spice": {
      "substitutable_within_subcategory": false,
      "notes": "Spices are NOT substitutable — cumin and cinnamon are completely different. Category-level matching for spices should be flagged as unreliable."
    },
    "condiment": {
      "substitutable_within_subcategory": false,
      "notes": "Condiments serve specific purposes — soy sauce and ketchup are not interchangeable."
    }
  },

